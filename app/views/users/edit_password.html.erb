<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&display=swap');

  .pw-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: #f5f2ed;
    font-family: 'DM Mono', monospace;
    position: relative;
    overflow: hidden;
  }

  .pw-page::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 10% 20%, rgba(210, 180, 140, 0.18) 0%, transparent 70%),
      radial-gradient(ellipse 50% 60% at 90% 80%, rgba(160, 130, 100, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .pw-card {
    width: 100%;
    max-width: 520px;
    background: #fff;
    border: 1px solid #e0d9d0;
    border-radius: 2px;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.04),
      0 8px 32px rgba(0,0,0,0.06),
      6px 6px 0 #d4c9b8;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .pw-card-header {
    padding: 2rem 2.5rem 1.5rem;
    border-bottom: 1px solid #f0ebe3;
    position: relative;
  }

  .pw-card-header::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 2.5rem;
    width: 2rem;
    height: 2px;
    background: #8b6f47;
  }

  .pw-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #a08060;
    margin: 0 0 0.6rem;
  }

  .pw-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.75rem;
    font-weight: 400;
    color: #2c2318;
    margin: 0;
    line-height: 1.2;
  }

  .pw-title em {
    font-style: italic;
    color: #8b6f47;
  }

  .pw-card-body {
    padding: 2rem 2.5rem 2.5rem;
  }

  /* Alert */
  .pw-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    background: #fff8f5;
    border: 1px solid #f5cfc4;
    border-left: 3px solid #c0432a;
    border-radius: 2px;
    margin-bottom: 1.75rem;
    font-size: 0.8rem;
    color: #7a2e1e;
    line-height: 1.5;
  }

  .pw-alert-icon {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    margin-top: 1px;
    opacity: 0.8;
  }

  /* Fields */
  .pw-section-label {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #b0987a;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed #e8e0d5;
  }

  .pw-field {
    margin-bottom: 1.25rem;
  }

  .pw-field label {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    color: #5c4a35;
    margin-bottom: 0.4rem;
    letter-spacing: 0.04em;
  }

  .pw-field label .pw-required {
    color: #c0432a;
    margin-left: 2px;
  }

  .pw-input-wrap {
    position: relative;
  }

  .pw-input {
    width: 100%;
    padding: 0.7rem 2.5rem 0.7rem 0.85rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    color: #2c2318;
    background: #faf8f5;
    border: 1px solid #ddd5c8;
    border-radius: 2px;
    outline: none;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    letter-spacing: 0.05em;
  }

  .pw-input:focus {
    border-color: #8b6f47;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(139, 111, 71, 0.1);
  }

  .pw-input.is-error {
    border-color: #c0432a;
    background: #fff9f8;
    box-shadow: 0 0 0 3px rgba(192, 67, 42, 0.08);
  }

  .pw-input.is-success {
    border-color: #4a8b5f;
    background: #f8fff9;
  }

  .pw-toggle {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: #b0987a;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }

  .pw-toggle:hover {
    color: #8b6f47;
  }

  .pw-hint {
    font-size: 0.67rem;
    color: #a8957e;
    margin-top: 0.35rem;
    letter-spacing: 0.02em;
  }

  .pw-hint.is-error {
    color: #c0432a;
  }

  .pw-divider {
    border: none;
    border-top: 1px dashed #e8e0d5;
    margin: 1.5rem 0 1.25rem;
  }

  /* Strength meter */
  .pw-strength {
    margin-top: 0.5rem;
    display: none;
  }

  .pw-strength.visible {
    display: block;
  }

  .pw-strength-bar {
    display: flex;
    gap: 3px;
    margin-bottom: 0.3rem;
  }

  .pw-strength-seg {
    flex: 1;
    height: 3px;
    background: #e8e0d5;
    border-radius: 99px;
    transition: background 0.3s;
  }

  .pw-strength-seg.active-weak   { background: #c0432a; }
  .pw-strength-seg.active-fair   { background: #c07a2a; }
  .pw-strength-seg.active-good   { background: #8b9e4a; }
  .pw-strength-seg.active-strong { background: #4a8b5f; }

  .pw-strength-label {
    font-size: 0.62rem;
    color: #a8957e;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Actions */
  .pw-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 2rem;
    align-items: center;
  }

  .pw-btn-primary {
    flex: 1;
    padding: 0.8rem 1.25rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: #2c2318;
    border: 1px solid #2c2318;
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
  }

  .pw-btn-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.06);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .pw-btn-primary:hover {
    background: #3d3222;
    box-shadow: 2px 2px 0 #8b6f47;
    transform: translate(-1px, -1px);
  }

  .pw-btn-primary:hover::after { opacity: 1; }
  .pw-btn-primary:active { transform: translate(0, 0); box-shadow: none; }

  .pw-btn-secondary {
    padding: 0.8rem 1.25rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: #8b6f47;
    background: transparent;
    border: 1px solid #ddd5c8;
    border-radius: 2px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .pw-btn-secondary:hover {
    border-color: #8b6f47;
    background: #faf5ef;
    color: #6b5035;
  }

  /* Loading state */
  .pw-btn-primary.loading {
    pointer-events: none;
    opacity: 0.7;
  }

  .pw-btn-primary.loading::before {
    content: '';
    display: inline-block;
    width: 10px;
    height: 10px;
    border: 1.5px solid rgba(255,255,255,0.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Entrance animation */
  .pw-card {
    animation: slideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .pw-field {
    animation: fadeIn 0.3s ease both;
  }

  .pw-field:nth-child(1) { animation-delay: 0.05s; }
  .pw-field:nth-child(2) { animation-delay: 0.1s; }
  .pw-field:nth-child(3) { animation-delay: 0.15s; }
  .pw-field:nth-child(4) { animation-delay: 0.2s; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 560px) {
    .pw-page { padding: 1rem; }
    .pw-card-header, .pw-card-body { padding-left: 1.5rem; padding-right: 1.5rem; }
    .pw-actions { flex-direction: column; }
    .pw-btn-secondary { width: 100%; justify-content: center; }
  }
</style>

<div class="pw-page">
  <div class="pw-card">

    <div class="pw-card-header">
      <p class="pw-eyebrow">Account Security</p>
      <h1 class="pw-title">Change <em>Password</em></h1>
    </div>

    <div class="pw-card-body">

      <%# Flash / error alert %>
      <% if flash[:alert] %>
        <div class="pw-alert" role="alert">
          <svg class="pw-alert-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 4.5v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="8" cy="11" r="0.75" fill="currentColor"/>
          </svg>
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: update_password_users_path, method: :patch, local: true, data: { turbo: false } do |f| %>

        <p class="pw-section-label">Current</p>

        <div class="pw-field">
          <%= label_tag :current_password do %>
            Current Password <span class="pw-required">*</span>
          <% end %>
          <div class="pw-input-wrap">
            <%= password_field_tag :current_password, nil,
                  id: "current_password",
                  class: "pw-input",
                  required: true,
                  autocomplete: "current-password",
                  placeholder: "••••••••" %>
            <button type="button" class="pw-toggle" data-target="current_password" aria-label="Toggle visibility">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
        </div>

        <hr class="pw-divider">
        <p class="pw-section-label">New Password</p>

        <div class="pw-field">
          <%= label_tag :password do %>
            New Password <span class="pw-required">*</span>
          <% end %>
          <div class="pw-input-wrap">
            <%= password_field_tag :password, nil,
                  id: "password",
                  class: "pw-input",
                  required: true,
                  autocomplete: "new-password",
                  placeholder: "••••••••",
                  minlength: 6 %>
            <button type="button" class="pw-toggle" data-target="password" aria-label="Toggle visibility">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
          <div class="pw-strength" id="strengthMeter">
            <div class="pw-strength-bar">
              <div class="pw-strength-seg" id="seg1"></div>
              <div class="pw-strength-seg" id="seg2"></div>
              <div class="pw-strength-seg" id="seg3"></div>
              <div class="pw-strength-seg" id="seg4"></div>
            </div>
            <span class="pw-strength-label" id="strengthLabel"></span>
          </div>
          <p class="pw-hint">Minimum 6 characters</p>
        </div>

        <div class="pw-field">
          <%= label_tag :password_confirmation do %>
            Confirm New Password <span class="pw-required">*</span>
          <% end %>
          <div class="pw-input-wrap">
            <%= password_field_tag :password_confirmation, nil,
                  id: "password_confirmation",
                  class: "pw-input",
                  required: true,
                  autocomplete: "new-password",
                  placeholder: "••••••••" %>
            <button type="button" class="pw-toggle" data-target="password_confirmation" aria-label="Toggle visibility">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            </button>
          </div>
          <p class="pw-hint" id="matchHint"></p>
        </div>

        <div class="pw-actions">
          <%= submit_tag "Update Password", class: "pw-btn-primary", id: "submitBtn" %>
          <%= link_to dashboard_path, class: "pw-btn-secondary" do %>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5M5 12l7 7M5 12l7-7"/>
            </svg>
            Cancel
          <% end %>
        </div>

      <% end %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {

    // --- Show/hide password toggles ---
    document.querySelectorAll('.pw-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var input = document.getElementById(btn.dataset.target);
        var isText = input.type === 'text';
        input.type = isText ? 'password' : 'text';

        btn.innerHTML = isText
          ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>'
          : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24M1 1l22 22"/></svg>';
      });
    });

    // --- Password strength meter ---
    var passwordInput = document.getElementById('password');
    var strengthMeter = document.getElementById('strengthMeter');
    var strengthLabel = document.getElementById('strengthLabel');
    var segs = [document.getElementById('seg1'), document.getElementById('seg2'), document.getElementById('seg3'), document.getElementById('seg4')];

    function getStrength(val) {
      var score = 0;
      if (val.length >= 6)  score++;
      if (val.length >= 10) score++;
      if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
      if (/[0-9]/.test(val) && /[^A-Za-z0-9]/.test(val)) score++;
      return score;
    }

    var levels = ['', 'weak', 'fair', 'good', 'strong'];
    var levelClass = ['', 'active-weak', 'active-fair', 'active-good', 'active-strong'];

    passwordInput.addEventListener('input', function () {
      var val = passwordInput.value;
      if (!val) {
        strengthMeter.classList.remove('visible');
        segs.forEach(function (s) { s.className = 'pw-strength-seg'; });
        return;
      }
      strengthMeter.classList.add('visible');
      var score = getStrength(val);
      segs.forEach(function (s, i) {
        s.className = 'pw-strength-seg' + (i < score ? ' ' + levelClass[score] : '');
      });
      strengthLabel.textContent = levels[score] ? levels[score].charAt(0).toUpperCase() + levels[score].slice(1) : '';
      checkMatch();
    });

    // --- Confirmation match ---
    var confirmInput = document.getElementById('password_confirmation');
    var matchHint   = document.getElementById('matchHint');

    function checkMatch() {
      var pw  = passwordInput.value;
      var cpw = confirmInput.value;
      if (!cpw) {
        matchHint.textContent = '';
        matchHint.className = 'pw-hint';
        confirmInput.classList.remove('is-error', 'is-success');
        return;
      }
      if (pw === cpw) {
        matchHint.textContent = 'Passwords match';
        matchHint.className = 'pw-hint';
        matchHint.style.color = '#4a8b5f';
        confirmInput.classList.remove('is-error');
        confirmInput.classList.add('is-success');
        confirmInput.setCustomValidity('');
      } else {
        matchHint.textContent = 'Passwords do not match';
        matchHint.className = 'pw-hint is-error';
        matchHint.style.color = '';
        confirmInput.classList.remove('is-success');
        confirmInput.classList.add('is-error');
        confirmInput.setCustomValidity("Passwords don't match");
      }
    }

    confirmInput.addEventListener('input', checkMatch);
    passwordInput.addEventListener('input', checkMatch);

    // --- Submit loading state ---
    var form   = document.querySelector('form');
    var submit = document.getElementById('submitBtn');
    form.addEventListener('submit', function () {
      submit.classList.add('loading');
      submit.value = 'Updating…';
    });

  });
</script>
