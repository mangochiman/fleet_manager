<div class="page-header">
  <h1>Change Password</h1>
  <p>Update your account password</p>
</div>

<div class="card">
  <div class="card-header">
    <h3>Password Details</h3>
  </div>
  <div class="card-body">
    <%= form_with url: update_password_users_path, method: :patch, local: true, class: "form", data: { turbo: false } do |f| %>

      <div class="grid grid-2">
        <div class="form-group full-width">
          <%= label_tag :current_password, "Current Password *" %>
          <%= password_field_tag :current_password, nil, 
                class: "form-control", 
                required: true, 
                autocomplete: "current-password",
                placeholder: "Enter your current password" %>
        </div>

        <div class="form-group">
          <%= label_tag :password, "New Password *" %>
          <%= password_field_tag :password, nil, 
                id: "password",
                class: "form-control", 
                required: true, 
                autocomplete: "new-password",
                placeholder: "Minimum 6 characters",
                minlength: 6 %>
          <small style="color: #64748b;">Minimum 6 characters</small>
        </div>

        <div class="form-group">
          <%= label_tag :password_confirmation, "Confirm New Password *" %>
          <%= password_field_tag :password_confirmation, nil, 
                id: "password_confirmation",
                class: "form-control", 
                required: true, 
                autocomplete: "new-password",
                placeholder: "Confirm your new password" %>
        </div>
      </div>

      <!-- Password strength indicator -->
      <div id="strengthMeter" style="margin-top: -0.5rem; margin-bottom: 1rem; display: none;">
        <div style="display: flex; gap: 0.25rem; margin-bottom: 0.25rem;">
          <div id="seg1" style="flex: 1; height: 3px; background: #e2e8f0; border-radius: 3px;"></div>
          <div id="seg2" style="flex: 1; height: 3px; background: #e2e8f0; border-radius: 3px;"></div>
          <div id="seg3" style="flex: 1; height: 3px; background: #e2e8f0; border-radius: 3px;"></div>
          <div id="seg4" style="flex: 1; height: 3px; background: #e2e8f0; border-radius: 3px;"></div>
        </div>
        <span id="strengthLabel" style="font-size: 0.65rem; color: #64748b;"></span>
      </div>

      <div id="matchHint" style="font-size: 0.7rem; margin-top: -0.5rem; margin-bottom: 1rem;"></div>

      <div style="margin-top: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
        <%= submit_tag "Change Password", class: "btn btn-primary", id: "submitBtn" %>
        <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
      </div>

    <% end %>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var passwordInput = document.getElementById('password');
    var confirmInput = document.getElementById('password_confirmation');
    var strengthMeter = document.getElementById('strengthMeter');
    var strengthLabel = document.getElementById('strengthLabel');
    var segs = [document.getElementById('seg1'), document.getElementById('seg2'), document.getElementById('seg3'), document.getElementById('seg4')];
    var matchHint = document.getElementById('matchHint');

    function getStrength(val) {
      var score = 0;
      if (val.length >= 6) score++;
      if (val.length >= 10) score++;
      if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
      if (/[0-9]/.test(val) && /[^A-Za-z0-9]/.test(val)) score++;
      return Math.min(score, 4);
    }

    var levels = ['', 'Weak', 'Fair', 'Good', 'Strong'];
    var colors = ['', '#c0432a', '#c07a2a', '#8b9e4a', '#4a8b5f'];

    passwordInput.addEventListener('input', function () {
      var val = passwordInput.value;
      if (!val) {
        strengthMeter.style.display = 'none';
        segs.forEach(function (s) { s.style.background = '#e2e8f0'; });
        return;
      }
      strengthMeter.style.display = 'block';
      var score = getStrength(val);
      segs.forEach(function (s, i) {
        s.style.background = i < score ? colors[score] : '#e2e8f0';
      });
      strengthLabel.textContent = levels[score] ? levels[score] + ' Password' : '';
      checkMatch();
    });

    function checkMatch() {
      var pw = passwordInput.value;
      var cpw = confirmInput.value;
      if (!cpw) {
        matchHint.textContent = '';
        confirmInput.style.borderColor = '';
        return;
      }
      if (pw === cpw) {
        matchHint.textContent = '✓ Passwords match';
        matchHint.style.color = '#10b981';
        confirmInput.style.borderColor = '#10b981';
      } else {
        matchHint.textContent = '✗ Passwords do not match';
        matchHint.style.color = '#ef4444';
        confirmInput.style.borderColor = '#ef4444';
      }
    }

    confirmInput.addEventListener('input', checkMatch);
    passwordInput.addEventListener('input', checkMatch);
  });
</script>