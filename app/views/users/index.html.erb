<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inconsolata:wght@300;400;500&display=swap');

  :root {
    --ink:     #0f1117;
    --ink-2:   #2a2d38;
    --ink-3:   #5c6070;
    --paper:   #f7f6f2;
    --surface: #ffffff;
    --border:  #e4e2da;
    --green:   #1a9e6e;
    --green-l: #e8f7f2;
    --red:     #d63d2f;
    --red-l:   #fdf0ee;
    --amber:   #c07b1a;
    --amber-l: #fef6e7;
    --blue:    #2563eb;
    --blue-l:  #eff4ff;
  }

  .um-wrap {
    font-family: 'Inconsolata', monospace;
    background: var(--paper);
    min-height: 100vh;
    padding: 2rem 2rem 3rem;
    color: var(--ink);
  }

  /* ── Header ── */
  .um-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1.5px solid var(--border);
    gap: 1rem;
    flex-wrap: wrap;
  }

  .um-eyebrow {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 0.3rem;
  }

  .um-title {
    font-family: 'Syne', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--ink);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .um-title span { color: var(--green); }

  /* ── Buttons ── */
  .um-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 0.9rem;
    font-family: 'Inconsolata', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 2px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .um-btn-primary {
    background: var(--ink);
    color: #fff;
    border-color: var(--ink);
  }

  .um-btn-primary:hover {
    background: var(--ink-2);
    box-shadow: 2px 2px 0 var(--green);
    transform: translate(-1px, -1px);
    color: #fff;
  }

  /* ── Panel ── */
  .um-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    overflow: hidden;
  }

  .um-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .um-panel-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin: 0;
  }

  /* ── Table ── */
  .um-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  .um-table thead tr {
    background: var(--paper);
    border-bottom: 1.5px solid var(--border);
  }

  .um-table th {
    text-align: left;
    padding: 0.6rem 1.1rem;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    white-space: nowrap;
  }

  .um-table td {
    padding: 0.7rem 1.1rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .um-table tbody tr:last-child td { border-bottom: none; }
  .um-table tbody tr { transition: background 0.12s; }
  .um-table tbody tr:hover { background: var(--paper); }

  .um-user-name  { display: block; font-weight: 600; color: var(--ink); }
  .um-user-email { display: block; font-size: 0.68rem; color: var(--ink-3); margin-top: 1px; }

  /* ── Role Badges ── */
  .um-badge {
    display: inline-block;
    padding: 0.18rem 0.5rem;
    border-radius: 2px;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .um-badge.super-admin,
  .um-badge.super_admin { background: var(--ink);     color: #fff; }
  .um-badge.manager     { background: var(--blue-l);  color: var(--blue); }
  .um-badge.driver      { background: var(--green-l); color: var(--green); }
  .um-badge.accountant  { background: var(--amber-l); color: var(--amber); }

  /* ── Action buttons ── */
  .um-action-group { display: flex; gap: 0.35rem; align-items: center; }

  .um-act {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.6rem;
    font-family: 'Inconsolata', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 2px;
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--ink-3);
    background: transparent;
    cursor: pointer;
    transition: all 0.12s;
    white-space: nowrap;
  }

  .um-act:hover { border-color: var(--ink-2); color: var(--ink); background: var(--paper); }

  .um-act.danger {
    color: var(--red);
    border-color: var(--red-l);
    background: var(--red-l);
  }

  .um-act.danger:hover { background: var(--red); color: #fff; border-color: var(--red); }

  /* ── Empty state ── */
  .um-empty {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--ink-3);
  }

  .um-empty-icon { font-size: 2.5rem; opacity: 0.3; margin-bottom: 0.75rem; }
  .um-empty p    { font-size: 0.8rem; margin: 0 0 0.5rem; }

  /* ── Mobile cards ── */
  .um-mobile { display: none; }

  .um-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    margin-bottom: 0.75rem;
    overflow: hidden;
    animation: statIn 0.35s ease both;
  }

  .um-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.65rem 1rem;
    background: var(--paper);
    border-bottom: 1px solid var(--border);
  }

  .um-card-name {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--ink);
  }

  .um-card-body { padding: 0.85rem 1rem; }

  .um-card-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.35rem 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
  }

  .um-card-key {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-3);
    padding-top: 1px;
  }

  .um-card-actions { display: flex; gap: 0.5rem; }
  .um-card-actions .um-act { flex: 1; justify-content: center; }

  @keyframes statIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .um-wrap    { padding: 1rem; }
    .um-title   { font-size: 1.5rem; }
    .um-desktop { display: none; }
    .um-mobile  { display: block; }
  }
</style>

<div class="um-wrap">

  <!-- Header -->
  <div class="um-header">
    <div>
      <p class="um-eyebrow">Fleet Management</p>
      <h1 class="um-title">User <span>Management</span></h1>
    </div>
    <%= link_to new_user_path, class: "um-btn um-btn-primary" do %>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
      Add User
    <% end %>
  </div>

  <!-- ── DESKTOP TABLE ── -->
  <div class="um-panel um-desktop">
    <div class="um-panel-head">
      <h3 class="um-panel-title">All Users</h3>
    </div>

    <% if @users.empty? %>
      <div class="um-empty">
        <div class="um-empty-icon">👤</div>
        <p>No users found.</p>
        <%= link_to "Add the first user →", new_user_path, class: "um-btn um-btn-primary" %>
      </div>
    <% else %>
      <table class="um-table">
        <thead>
          <tr>
            <th>Name / Email</th>
            <th>Phone</th>
            <th>Role</th>
            <th>Assigned Vehicle</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td>
                <span class="um-user-name"><%= user.name %></span>
                <span class="um-user-email"><%= user.email %></span>
              </td>
              <td><%= user.phone || '—' %></td>
              <td>
                <span class="um-badge <%= user.role_name.parameterize %>">
                  <%= user.role_name.titleize %>
                </span>
              </td>
              <td><%= user.vehicle_id.present? ? (user.vehicle&.registration_number || 'Not assigned') : '—' %></td>
              <td>
                <div class="um-action-group">
                  <%= link_to "Edit", edit_user_path(user), class: "um-act" %>
                  <% if user != current_user %>
                    <%= button_to "Delete", user, method: :delete, class: "um-act danger",
                          form: { style: "display: contents;", data: { turbo_confirm: "Are you sure? This action cannot be undone." } } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

  <!-- ── MOBILE CARDS ── -->
  <div class="um-mobile">
    <% @users.each_with_index do |user, i| %>
      <div class="um-card" style="animation-delay: <%= i * 0.04 %>s;">
        <div class="um-card-head">
          <span class="um-card-name"><%= user.name %></span>
          <span class="um-badge <%= user.role_name.parameterize %>">
            <%= user.role_name.titleize %>
          </span>
        </div>
        <div class="um-card-body">
          <div class="um-card-grid">
            <span class="um-card-key">Email</span>
            <span><%= user.email %></span>

            <span class="um-card-key">Phone</span>
            <span><%= user.phone || '—' %></span>

            <span class="um-card-key">Vehicle</span>
            <span><%= user.vehicle_id.present? ? (user.vehicle&.registration_number || 'Not assigned') : '—' %></span>
          </div>

          <div class="um-card-actions">
            <%= link_to "Edit", edit_user_path(user), class: "um-act" %>
            <% if user != current_user %>
              <%= button_to "Delete", user, method: :delete, class: "um-act danger",
                    form: { style: "display: contents;", data: { turbo_confirm: "Are you sure? This action cannot be undone." } } %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if @users.empty? %>
      <div class="um-empty">
        <div class="um-empty-icon">👤</div>
        <p>No users found.</p>
        <%= link_to "Add the first user →", new_user_path, class: "um-btn um-btn-primary" %>
      </div>
    <% end %>
  </div>

</div>
