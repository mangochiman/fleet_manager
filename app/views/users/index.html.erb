<div class="page-header">
  <h1>User Management</h1>
  <p>Manage system users and their roles</p>
</div>

<div class="card">
  <div class="card-header">
    <h3>All Users</h3>
    <%= link_to "+ Add New User", new_user_path, class: "btn btn-primary btn-sm" %>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Role</th>
            <th>Assigned Vehicle</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td data-label="Name"><strong><%= user.name %></strong></td>
              <td data-label="Email"><%= user.email %></td>
              <td data-label="Phone"><%= user.phone || '—' %></td>
              <td data-label="Role">
                <span class="badge badge-<%= user.role_name %>">
                  <%= user.role_name.titleize %>
                </span>
              </td>
              <td data-label="Vehicle">
                <% if user.vehicle_id.present? %>
                  <%= user.vehicle&.registration_number || 'Not assigned' %>
                <% else %>
                  —
                <% end %>
              </td>
              <td data-label="Actions" style="white-space: nowrap;">
                <%= link_to "Edit", edit_user_path(user), class: "btn btn-secondary btn-sm" %>
                <% if user != current_user %>
                  <%= button_to "Delete", user, method: :delete, class: "btn btn-danger btn-sm", form: { style: "display: inline-block;", data: { turbo_confirm: "Are you sure? This action cannot be undone." } } %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>