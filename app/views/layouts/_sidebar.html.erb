<!-- Sidebar -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="logo">🚛</div>
    <h2>Fleet Manager</h2>
    <p class="user-greeting"><%= current_user.name %></p>
    <span class="user-role"><%= current_user.role_name %></span>
  </div>
  
  <nav class="sidebar-nav">
    <!-- Dashboard - Everyone can see -->
    <%= link_to dashboard_path, class: "nav-link #{'active' if current_page?(dashboard_path) || current_page?(root_path)}" do %>
      <span class="nav-icon">📊</span>
      <span>Dashboard</span>
    <% end %>
    
    <!-- Sales - Everyone can see -->
    <%= link_to sales_path, class: "nav-link #{'active' if controller_name == 'sales'}" do %>
      <span class="nav-icon">💰</span>
      <span>Sales</span>
    <% end %>
    
    <!-- Expenses - Only Admins, Managers, and Super Admins -->
    <% if current_user.admin? || current_user.manager? || current_user.super_admin? %>
      <%= link_to expenses_path, class: "nav-link #{'active' if controller_name == 'expenses'}" do %>
        <span class="nav-icon">💸</span>
        <span>Expenses</span>
      <% end %>
    <% end %>
    
    <!-- Vehicles - Only Admins, Managers, and Super Admins -->
    <% if current_user.admin? || current_user.manager? || current_user.super_admin? %>
      <%= link_to vehicles_path, class: "nav-link #{'active' if controller_name == 'vehicles'}" do %>
        <span class="nav-icon">🚚</span>
        <span>Vehicles</span>
      <% end %>
    <% end %>
    
    <!-- Products - Only Admins, Managers, and Super Admins -->
    <% if current_user.admin? || current_user.manager? || current_user.super_admin? %>
      <%= link_to products_path, class: "nav-link #{'active' if controller_name == 'products'}" do %>
        <span class="nav-icon">📦</span>
        <span>Products</span>
      <% end %>
    <% end %>
    
    <!-- Reports - Only Managers and Super Admins -->
    <% if current_user.manager? || current_user.super_admin? %>
      <%= link_to reports_path, class: "nav-link #{'active' if controller_name == 'reports'}" do %>
        <span class="nav-icon">📈</span>
        <span>Reports</span>
      <% end %>
    <% end %>
    
    <!-- Users Management - Only Super Admins -->
    <% if current_user.super_admin? %>
      <%= link_to users_path, class: "nav-link #{'active' if controller_name == 'users'}" do %>
        <span class="nav-icon">👥</span>
        <span>Users</span>
      <% end %>
    <% end %>
    
    <div class="nav-divider"></div>
    
    <!-- Logout - Everyone can see -->
    <%= link_to destroy_user_session_path, data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to logout?" }, class: "nav-link logout" do %>
      <span class="nav-icon">🚪</span>
      <span>Logout</span>
    <% end %>
  </nav>
</aside>