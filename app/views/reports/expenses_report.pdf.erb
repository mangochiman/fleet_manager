<style>
  body {
    font-family: 'Helvetica', 'Arial', sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: #1e293b;
    margin: 0;
    padding: 20px;
  }

  .report-header {
    text-align: center;
    margin-bottom: 35px;
    padding-bottom: 20px;
    border-bottom: 3px solid #ef4444;
  }

  .company-name {
    font-size: 16px;
    font-weight: 700;
    color: #ef4444;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .report-title {
    font-size: 32px;
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 10px 0;
    letter-spacing: -0.5px;
  }

  .report-meta {
    font-size: 14px;
    color: #64748b;
    margin: 5px 0;
  }

  .summary-grid {
    display: flex;
    gap: 15px;
    margin-bottom: 35px;
  }

  .summary-card {
    flex: 1;
    background: #f8fafc;
    border-radius: 8px;
    padding: 18px 12px;
    text-align: center;
    border-top: 3px solid #ef4444;
  }

  .summary-card .label {
    font-size: 11px;
    font-weight: 700;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .summary-card .value {
    font-size: 24px;
    font-weight: 700;
    color: #1e293b;
  }

  .positive { color: #10b981; font-weight: 700; }
  .negative { color: #ef4444; font-weight: 700; }
  .neutral  { color: #ef4444; font-weight: 700; }

  .section-title {
    font-size: 11px;
    font-weight: 700;
    color: #ef4444;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 30px 0 12px 0;
    padding-bottom: 8px;
    border-bottom: 2px solid #e2e8f0;
  }

  .report-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 25px;
    font-size: 13px;
  }

  .report-table th {
    background: #1e293b;
    color: #f8fafc;
    padding: 11px 10px;
    text-align: left;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .report-table td {
    padding: 10px;
    border-bottom: 1px solid #e2e8f0;
    color: #334155;
    vertical-align: middle;
    font-size: 13px;
  }

  .report-table tbody tr:nth-child(even) td {
    background: #f8fafc;
  }

  .report-table tfoot td {
    padding: 12px 10px;
    background: #1e293b;
    color: #f8fafc;
    font-weight: 700;
    border-top: 2px solid #ef4444;
    font-size: 14px;
  }

  .report-table tfoot .negative {
    color: #fca5a5;
  }

  .text-right  { text-align: right; }
  .text-center { text-align: center; }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .badge-fuel      { background: #fef3c7; color: #d97706; }
  .badge-service   { background: #dbeafe; color: #2563eb; }
  .badge-tires     { background: #e0e7ff; color: #4338ca; }
  .badge-salaries  { background: #d1fae5; color: #059669; }
  .badge-breakdown { background: #fee2e2; color: #dc2626; }
  .badge-others    { background: #f3e8ff; color: #9333ea; }

  .footer {
    margin-top: 40px;
    padding-top: 15px;
    border-top: 1px solid #e2e8f0;
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: #94a3b8;
  }
</style>

<%# ── Header ─────────────────────────────────────────────── %>
<div class="report-header">
  <div class="company-name">Fleet Management System</div>
  <div class="report-title">Expenses Report</div>
  <p class="report-meta">
    Period: <strong><%= @start_date.strftime("%B %d, %Y") %></strong>
    &mdash;
    <strong><%= @end_date.strftime("%B %d, %Y") %></strong>
  </p>
  <p class="report-meta">Generated: <%= Time.current.strftime("%B %d, %Y at %I:%M %p") %></p>
</div>

<%# ── Summary Cards ───────────────────────────────────────── %>
<div class="summary-grid">
  <div class="summary-card">
    <div class="label">Total Transactions</div>
    <div class="value neutral"><%= number_with_delimiter(@total_transactions) %></div>
  </div>
  <div class="summary-card">
    <div class="label">Total Expenses</div>
    <div class="value negative"><%= number_to_currency(@total_expenses) %></div>
  </div>
  <div class="summary-card">
    <div class="label">Avg Expense</div>
    <div class="value"><%= number_to_currency(@total_transactions > 0 ? @total_expenses / @total_transactions : 0) %></div>
  </div>
  <div class="summary-card">
    <div class="label">Reporting Period</div>
    <div class="value"><%= ((@end_date - @start_date).to_i + 1) %> days</div>
  </div>
</div>

<%# ── Expenses by Category ────────────────────────────────── %>
<div class="section-title">Expenses by Category</div>
<table class="report-table">
  <thead>
    <tr>
      <th>Category</th>
      <th class="text-right">Amount</th>
      <th class="text-right">% of Total</th>
    </tr>
  </thead>
  <tbody>
    <% @expenses_by_category.each do |category, amount| %>
      <tr>
        <td><span class="badge badge-<%= category %>"><%= category.titleize %></span></td>
        <td class="text-right negative"><%= number_to_currency(amount) %></td>
        <td class="text-right">
          <%= number_to_percentage((amount / @total_expenses.to_f * 100), precision: 1) if @total_expenses > 0 %>
        </td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr>
      <td><strong>Total</strong></td>
      <td class="text-right negative"><strong><%= number_to_currency(@total_expenses) %></strong></td>
      <td class="text-right"><strong>100%</strong></td>
    </tr>
  </tfoot>
</table>

<%# ── Detailed Expense List ───────────────────────────────── %>
<div class="section-title">Detailed Expense List</div>
<table class="report-table">
  <thead>
    <tr>
      <th>Date</th>
      <th>Vehicle</th>
      <th>Category</th>
      <th>Description</th>
      <th class="text-right">Amount</th>
      <th>Recorded By</th>
    </tr>
  </thead>
  <tbody>
    <% @expenses.each do |expense| %>
      <tr>
        <td><strong><%= expense.expense_date.strftime("%d %b %Y") %></strong></td>
        <td><%= expense.vehicle.registration_number %></td>
        <td><span class="badge badge-<%= expense.category %>"><%= expense.category.titleize %></span></td>
        <td><%= truncate(expense.description, length: 60) %></td>
        <td class="text-right negative"><%= number_to_currency(expense.amount) %></td>
        <td><%= expense.recorded_by&.name || 'System' %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr>
      <td colspan="4" class="text-right">Grand Total</td>
      <td class="text-right negative"><strong><%= number_to_currency(@total_expenses) %></strong></td>
      <td></td>
    </tr>
  </tfoot>
</table>

<%# ── Footer ─────────────────────────────────────────────── %>
<div class="footer">
  <span>Fleet Management System &copy; <%= Date.current.year %> &mdash; Confidential</span>
  <span>This report is computer-generated and does not require a signature.</span>
</div>