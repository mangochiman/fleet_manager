<div class="page-header">
  <h1>Vehicles</h1>
  <p>Manage your fleet of vehicles</p>
</div>

<!-- Compact Stats Bar -->
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
  <div style="background: white; border-radius: 0.5rem; padding: 0.75rem 1rem; box-shadow: 0 1px 2px rgba(0,0,0,0.05); border-left: 3px solid #10b981;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <div>
        <div style="font-size: 0.7rem; color: #64748b;">Total Vehicles</div>
        <div style="font-size: 1.25rem; font-weight: 700; color: #1e293b;"><%= @total_vehicles %></div>
      </div>
      <div style="font-size: 1.5rem;">🚛</div>
    </div>
  </div>
  
  <div style="background: white; border-radius: 0.5rem; padding: 0.75rem 1rem; box-shadow: 0 1px 2px rgba(0,0,0,0.05); border-left: 3px solid #10b981;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <div>
        <div style="font-size: 0.7rem; color: #64748b;">Active</div>
        <div style="font-size: 1.25rem; font-weight: 700; color: #1e293b;"><%= @active_vehicles %></div>
      </div>
      <div style="font-size: 1.5rem;">✅</div>
    </div>
  </div>
  
  <div style="background: white; border-radius: 0.5rem; padding: 0.75rem 1rem; box-shadow: 0 1px 2px rgba(0,0,0,0.05); border-left: 3px solid #f59e0b;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <div>
        <div style="font-size: 0.7rem; color: #64748b;">Maintenance</div>
        <div style="font-size: 1.25rem; font-weight: 700; color: #1e293b;"><%= @maintenance_vehicles %></div>
      </div>
      <div style="font-size: 1.5rem;">🔧</div>
    </div>
  </div>
  
  <div style="background: white; border-radius: 0.5rem; padding: 0.75rem 1rem; box-shadow: 0 1px 2px rgba(0,0,0,0.05); border-left: 3px solid #10b981;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <div>
        <div style="font-size: 0.7rem; color: #64748b;">Total Profit</div>
        <div style="font-size: 1rem; font-weight: 700; color: #1e293b;"><%= number_to_currency(@total_profit) %></div>
      </div>
      <div style="font-size: 1.5rem;">💰</div>
    </div>
  </div>
</div>

<!-- Search and Filter Bar -->
<div style="margin-bottom: 1.5rem;">
  <%= form_tag vehicles_path, method: :get, style: "display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center;" do %>
    <%= text_field_tag :search, params[:search], placeholder: "Search by reg, make, or model...", class: "form-control", style: "flex: 1; min-width: 150px;" %>
    <%= select_tag :status, options_for_select([["All Status", ""], ["Active", "active"], ["Maintenance", "maintenance"], ["Retired", "retired"]], params[:status]), class: "form-control", style: "width: auto; min-width: 120px;" %>
    
    <div style="display: flex; align-items: center; gap: 0.5rem;">
      <span style="font-size: 0.75rem; color: #64748b;">Show:</span>
      <%= select_tag :per_page, options_for_select([10, 20, 50], params[:per_page] || 10), class: "form-control", style: "width: auto; min-width: 65px;", onchange: "this.form.submit()" %>
    </div>
    
    <%= submit_tag "Filter", class: "btn btn-primary btn-sm" %>
    <%= link_to "Clear", vehicles_path, class: "btn btn-secondary btn-sm" %>
    <%= link_to "+ Add Vehicle", new_vehicle_path, class: "btn btn-primary btn-sm" %>
  <% end %>
</div>

<!-- Vehicles Table -->
<div class="card">
  <div class="card-header">
    <h3>All Vehicles</h3>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Registration</th>
            <th>Make & Model</th>
            <th>Year</th>
            <th>Status</th>
            <th>Revenue</th>
            <th>Expenses</th>
            <th>Profit</th>
            <th>Margin</th>
            <th style="width: 100px;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @vehicles.each do |vehicle| %>
            <tr>
              <td data-label="Registration"><strong><%= vehicle.registration_number %></strong></td>
              <td data-label="Make & Model"><%= "#{vehicle.make} #{vehicle.model}" %></td>
              <td data-label="Year"><%= vehicle.year %></td>
              <td data-label="Status">
                <span class="badge <%= vehicle.status_badge_class %>">
                  <%= vehicle.status.titleize %>
                </span>
              </td>
              <td data-label="Revenue" class="positive"><%= number_to_currency(vehicle.total_sales) %></td>
              <td data-label="Expenses" class="negative"><%= number_to_currency(vehicle.total_expenses) %></td>
              <td data-label="Profit" class="<%= vehicle.profit >= 0 ? 'positive' : 'negative' %>">
                <%= number_to_currency(vehicle.profit) %>
              </td>
              <td data-label="Margin">
                <span class="<%= vehicle.profit_margin >= 0 ? 'positive' : 'negative' %>">
                  <%= vehicle.profit_margin %>%
                </span>
              </td>
              <td data-label="Actions" style="white-space: nowrap;">
                <%= link_to "View", vehicle, class: "btn btn-secondary btn-sm" %>
                <%= link_to "Edit", edit_vehicle_path(vehicle), class: "btn btn-secondary btn-sm" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <% if @vehicles.empty? %>
      <div style="text-align: center; padding: 3rem; color: #64748b;">
        No vehicles found. <%= link_to "Add your first vehicle", new_vehicle_path %>.
      </div>
    <% end %>
  </div>
</div>

<!-- Pagination -->
<% if @vehicles.total_entries > 0 %>
  <div style="margin-top: 1.5rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
      <div style="font-size: 0.75rem; color: #64748b;">
        <% if @vehicles.total_pages > 1 %>
          <%= @vehicles.offset + 1 %> - <%= [@vehicles.offset + @vehicles.length, @vehicles.total_entries].min %> of <%= @vehicles.total_entries %> vehicles
        <% else %>
          All <%= @vehicles.total_entries %> vehicles
        <% end %>
      </div>
      
      <% if @vehicles.total_pages > 1 %>
        <%= will_paginate @vehicles, 
              renderer: WillPaginate::ActionView::BootstrapLinkRenderer,
              previous_label: '←',
              next_label: '→',
              class: 'pagination' %>
      <% end %>
    </div>
  </div>
<% end %>