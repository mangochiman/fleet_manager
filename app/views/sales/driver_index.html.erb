<div class="dashboard-container">
  <!-- Header -->
  <div class="page-header">
    <h1>Ma trip anga</h1>
    <p>Dziwani za ma trip anu</p>
  </div>

  <!-- Stats Cards -->
  <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); margin-bottom: 1.5rem;">
    <div class="stat-card" style="padding: 0.75rem;">
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <div>
          <div style="font-size: 0.7rem; color: #64748b;">Ma trip onse anga</div>
          <div style="font-size: 1.25rem; font-weight: 700; color: #1e293b;"><%= @total_trips %></div>
        </div>
        <div style="font-size: 1.5rem;">🚛</div>
      </div>
    </div>

    <div class="stat-card" style="padding: 0.75rem;">
      <div style="display: flex; align-items: center; justify-content: space-between;">
        <div>
          <div style="font-size: 0.7rem; color: #64748b;">Ma trip anga a mwezi uno</div>
          <div style="font-size: 1.25rem; font-weight: 700; color: #1e293b;"><%= @monthly_trips %></div>
        </div>
        <div style="font-size: 1.5rem;">📅</div>
      </div>
    </div>
  </div>

  <!-- New Trip Button -->
  <div style="margin-bottom: 1.5rem;">
    <%= link_to new_sale_path, class: "btn btn-primary" do %>
      + Trip yanyuwani
    <% end %>
  </div>
</div>