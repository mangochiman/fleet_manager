<div class="page-header">
  <h1>Edit Sale Transaction</h1>
  <p>Update sale details for <%= @sale.transaction_id %></p>
</div>

<div class="card">
  <div class="card-header">
    <h3>Edit Sale Details</h3>
  </div>
  <div class="card-body">
    <%= form_with(model: @sale, class: "form") do |f| %>
      <% if @sale.errors.any? %>
        <div class="alert alert-danger">
          <h4><%= pluralize(@sale.errors.count, "error") %> prohibited this sale from being saved:</h4>
          <ul>
            <% @sale.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      
      <div class="grid grid-2">
        <div class="form-group">
          <%= f.label :customer_name, "Customer Name *" %>
          <%= f.text_field :customer_name, class: "form-control", required: true %>
        </div>
        
        <div class="form-group">
          <%= f.label :customer_phone, "Customer Phone" %>
          <%= f.telephone_field :customer_phone, class: "form-control" %>
        </div>
        
        <div class="form-group">
          <%= f.label :product_id, "Product *" %>
          <%= f.collection_select :product_id, @products, :id, :name, { prompt: "Select product" }, class: "form-control", required: true %>
        </div>
        
        <div class="form-group">
          <%= f.label :vehicle_id, "Vehicle *" %>
          <%= f.collection_select :vehicle_id, @vehicles, :id, :display_name, { prompt: "Select vehicle" }, class: "form-control", required: true %>
        </div>
        
        <div class="form-group">
          <%= f.label :quantity, "Quantity *" %>
          <%= f.number_field :quantity, class: "form-control", step: "any", required: true %>
        </div>
        
        <div class="form-group">
          <%= f.label :unit_price, "Unit Price *" %>
          <%= f.number_field :unit_price, class: "form-control", step: "any", required: true %>
        </div>
        
        <div class="form-group">
          <%= f.label :transaction_date, "Transaction Date *" %>
          <%= f.date_field :transaction_date, class: "form-control", required: true %>
        </div>
        
        <div class="form-group full-width">
          <%= f.label :notes, "Notes" %>
          <%= f.text_area :notes, class: "form-control", rows: 3 %>
        </div>
      </div>
      
      <div style="margin-top: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
        <%= f.submit "Update Sale", class: "btn btn-primary" %>
        <%= link_to "Cancel", @sale, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>