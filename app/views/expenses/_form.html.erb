<%= form_with(model: expense, local: true, multipart: true, class: "form") do |f| %>
  <% if expense.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(expense.errors.count, "error") %> prohibited this expense from being saved:</h4>
      <ul>
        <% expense.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <div class="grid grid-2">
    <div class="form-group">
      <%= f.label :vehicle_id, "Vehicle *" %>
      <%= f.collection_select :vehicle_id, @vehicles, :id, :display_name, { prompt: "Select vehicle" }, class: "form-control", required: true %>
    </div>
    
    <div class="form-group">
      <%= f.label :category, "Category *" %>
      <%= f.select :category, Expense::CATEGORIES.map { |k, v| [v, k] }, { prompt: "Select category" }, class: "form-control", required: true %>
    </div>
    
    <div class="form-group">
      <%= f.label :amount, "Amount *" %>
      <%= f.number_field :amount, class: "form-control", step: "any", placeholder: "0.00", required: true %>
    </div>
    
    <div class="form-group">
      <%= f.label :expense_date, "Expense Date *" %>
      <%= f.date_field :expense_date, class: "form-control", value: Date.current, required: true %>
    </div>
    
    <div class="form-group full-width">
      <%= f.label :description, "Description *" %>
      <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Enter detailed description of the expense...", required: true %>
    </div>
    
    <div class="form-group full-width">
      <%= f.label :receipt, "Receipt (Optional)" %>
      <%= f.file_field :receipt, class: "form-control", accept: "image/*,application/pdf" %>
      <small style="color: #64748b;">Upload receipt or invoice (image or PDF)</small>
      <% if expense.receipt.attached? %>
        <div style="margin-top: 0.5rem;">
          <span style="font-size: 0.75rem; color: #10b981;">✓ Current receipt: <%= link_to expense.receipt.filename, receipt_expense_path(expense), target: "_blank" %></span>
        </div>
      <% end %>
    </div>
  </div>
  
  <div style="margin-top: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
    <%= f.submit submit_text, class: "btn btn-primary" %>
    <%= link_to "Cancel", expenses_path, class: "btn btn-secondary" %>
  </div>
<% end %>
