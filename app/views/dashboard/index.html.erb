<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inconsolata:wght@300;400;500&display=swap');

  :root {
    --ink:     #0f1117;
    --ink-2:   #2a2d38;
    --ink-3:   #5c6070;
    --paper:   #f7f6f2;
    --surface: #ffffff;
    --border:  #e4e2da;
    --green:   #1a9e6e;
    --green-l: #e8f7f2;
    --red:     #d63d2f;
    --red-l:   #fdf0ee;
    --amber:   #c07b1a;
    --amber-l: #fef6e7;
    --blue:    #2563eb;
    --blue-l:  #eff4ff;
  }

  .db-wrap {
    font-family: 'Inconsolata', monospace;
    background: var(--paper);
    min-height: 100vh;
    padding: 2rem 2rem 3rem;
    color: var(--ink);
  }

  /* ── Header ── */
  .db-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1.5px solid var(--border);
    gap: 1rem;
    flex-wrap: wrap;
  }

  .db-header-left {}

  .db-eyebrow {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 0.3rem;
  }

  .db-title {
    font-family: 'Syne', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--ink);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .db-title span {
    color: var(--green);
  }

  .db-date {
    font-size: 0.7rem;
    color: var(--ink-3);
    margin-top: 0.4rem;
    letter-spacing: 0.04em;
  }

  /* ── Stat Cards ── */
  .db-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .db-stat {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 1rem 1.1rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    animation: statIn 0.4s cubic-bezier(0.22,1,0.36,1) both;
  }

  .db-stat:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.07);
  }

  .db-stat::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
  }

  .db-stat.green::before  { background: var(--green); }
  .db-stat.red::before    { background: var(--red); }
  .db-stat.amber::before  { background: var(--amber); }
  .db-stat.blue::before   { background: var(--blue); }

  .db-stat-label {
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 0.35rem;
  }

  .db-stat-value {
    font-family: 'Syne', sans-serif;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .db-stat-sub {
    font-size: 0.62rem;
    letter-spacing: 0.04em;
  }

  .db-stat.green  .db-stat-sub { color: var(--green); }
  .db-stat.red    .db-stat-sub { color: var(--red); }
  .db-stat.amber  .db-stat-sub { color: var(--amber); }
  .db-stat.blue   .db-stat-sub { color: var(--blue); }

  .db-stat-icon {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.4rem;
    opacity: 0.18;
  }

  .db-stat:nth-child(1) { animation-delay: 0.05s; }
  .db-stat:nth-child(2) { animation-delay: 0.10s; }
  .db-stat:nth-child(3) { animation-delay: 0.15s; }
  .db-stat:nth-child(4) { animation-delay: 0.20s; }

  @keyframes statIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Panels ── */
  .db-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 3px;
    overflow: hidden;
  }

  .db-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--border);
  }

  .db-panel-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin: 0;
  }

  .db-panel-link {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.15s;
  }

  .db-panel-link:hover { opacity: 0.7; }

  .db-panel-body {
    padding: 1.1rem;
  }

  .db-panel-body.no-pad { padding: 0; }

  /* ── Charts row ── */
  .db-charts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 0.85rem;
    margin-bottom: 0.85rem;
  }

  .db-chart-wrap {
    position: relative;
    width: 100%;
  }

  /* ── Table shared ── */
  .db-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
  }

  .db-table thead tr {
    background: var(--paper);
    border-bottom: 1.5px solid var(--border);
  }

  .db-table th {
    text-align: left;
    padding: 0.6rem 1.1rem;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    white-space: nowrap;
  }

  .db-table td {
    padding: 0.65rem 1.1rem;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .db-table tbody tr:last-child td { border-bottom: none; }

  .db-table tbody tr {
    transition: background 0.15s;
  }

  .db-table tbody tr:hover {
    background: var(--paper);
  }

  /* ── Vehicle performance ── */
  .db-vehicle { margin-bottom: 0.85rem; }

  .text-green  { color: var(--green); font-weight: 500; }
  .text-red    { color: var(--red);   font-weight: 500; }
  .text-amber  { color: var(--amber); font-weight: 500; }
  .text-ink    { color: var(--ink); }
  .text-mono   { font-family: 'Inconsolata', monospace; }

  /* Progress bar */
  .db-progress {
    height: 4px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
    min-width: 80px;
  }

  .db-progress-fill {
    height: 100%;
    background: var(--green);
    border-radius: 99px;
    transition: width 0.6s cubic-bezier(0.22,1,0.36,1);
  }

  /* ── Badge ── */
  .db-badge {
    display: inline-block;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .db-badge.paid      { background: var(--green-l); color: var(--green); }
  .db-badge.pending   { background: var(--amber-l); color: var(--amber); }
  .db-badge.overdue   { background: var(--red-l);   color: var(--red); }
  .db-badge.partial   { background: var(--blue-l);  color: var(--blue); }

  /* ── Two-col bottom ── */
  .db-bottom {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }

  @media (max-width: 700px) {
    .db-bottom { grid-template-columns: 1fr; }
    .db-title  { font-size: 1.5rem; }
    .db-wrap   { padding: 1rem; }
  }
</style>

<div class="db-wrap">

  <!-- Header -->
  <div class="db-header">
    <div class="db-header-left">
      <p class="db-eyebrow">Fleet Management</p>
      <h1 class="db-title"><%= time_of_day_greeting %>, <span><%= current_user.name.split.first %></span></h1>
      <p class="db-date"><%= Date.today.strftime("%-d %B %Y — %A") %></p>
    </div>
  </div>

  <!-- Stat Cards -->
  <div class="db-stats">
    <div class="db-stat green">
      <div class="db-stat-label">Total Revenue</div>
      <div class="db-stat-value"><%= number_to_currency(@total_revenue) %></div>
      <div class="db-stat-sub">↑ +12% from last month</div>
      <div class="db-stat-icon">💰</div>
    </div>

    <div class="db-stat red">
      <div class="db-stat-label">Total Expenses</div>
      <div class="db-stat-value"><%= number_to_currency(@total_expenses) %></div>
      <div class="db-stat-sub">↓ Within budget</div>
      <div class="db-stat-icon">📊</div>
    </div>

    <div class="db-stat green">
      <div class="db-stat-label">Net Profit</div>
      <div class="db-stat-value"><%= number_to_currency(@net_profit) %></div>
      <div class="db-stat-sub">↑ +8% growth</div>
      <div class="db-stat-icon">🎯</div>
    </div>

    <div class="db-stat amber">
      <div class="db-stat-label">Outstanding</div>
      <div class="db-stat-value"><%= number_to_currency(@outstanding_amount) %></div>
      <div class="db-stat-sub"><%= @outstanding_count %> pending</div>
      <div class="db-stat-icon">⏳</div>
    </div>
  </div>

  <!-- Charts -->
  <div class="db-charts">
    <div class="db-panel">
      <div class="db-panel-head">
        <h3 class="db-panel-title">Revenue vs Expenses</h3>
      </div>
      <div class="db-panel-body">
        <div class="db-chart-wrap">
          <canvas id="revenueExpenseChart"></canvas>
        </div>
      </div>
    </div>

    <div class="db-panel">
      <div class="db-panel-head">
        <h3 class="db-panel-title">Expense Breakdown</h3>
      </div>
      <div class="db-panel-body">
        <div class="db-chart-wrap">
          <canvas id="expenseBreakdownChart"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Vehicle Performance -->
  <div class="db-panel db-vehicle">
    <div class="db-panel-head">
      <h3 class="db-panel-title">Vehicle Performance</h3>
    </div>
    <div class="db-panel-body no-pad">
      <table class="db-table">
        <thead>
          <tr>
            <th>Vehicle</th>
            <th>Revenue</th>
            <th>Expenses</th>
            <th>Profit</th>
            <th>Margin</th>
          </tr>
        </thead>
        <tbody>
          <% @vehicle_performance.each do |vehicle| %>
            <tr>
              <td><strong class="text-mono"><%= vehicle[:name] %></strong></td>
              <td class="text-green"><%= number_to_currency(vehicle[:sales]) %></td>
              <td class="text-red"><%= number_to_currency(vehicle[:expenses]) %></td>
              <td class="<%= vehicle[:profit] >= 0 ? 'text-green' : 'text-red' %>">
                <%= number_to_currency(vehicle[:profit]) %>
              </td>
              <td style="min-width: 100px;">
                <div class="db-progress">
                  <div class="db-progress-fill" style="width: <%= vehicle[:profit] > 0 && vehicle[:sales] > 0 ? [((vehicle[:profit] / vehicle[:sales].to_f) * 100).round, 100].min : 0 %>%;"></div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Recent Transactions -->
  <div class="db-bottom">
    <div class="db-panel">
      <div class="db-panel-head">
        <h3 class="db-panel-title">Recent Sales</h3>
        <%= link_to "View All →", sales_path, class: "db-panel-link" %>
      </div>
      <div class="db-panel-body no-pad">
        <table class="db-table">
          <thead>
            <tr>
              <th>Customer</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_sales.each do |sale| %>
              <tr>
                <td><%= sale.customer_name %></td>
                <td class="text-green"><%= number_to_currency(sale.total_amount) %></td>
                <td>
                  <span class="db-badge <%= sale.payment_status %>">
                    <%= sale.payment_status.titleize %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="db-panel">
      <div class="db-panel-head">
        <h3 class="db-panel-title">Recent Expenses</h3>
        <%= link_to "View All →", expenses_path, class: "db-panel-link" %>
      </div>
      <div class="db-panel-body no-pad">
        <table class="db-table">
          <thead>
            <tr>
              <th>Vehicle</th>
              <th>Category</th>
              <th>Amount</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_expenses.each do |expense| %>
              <tr>
                <td class="text-mono"><%= expense.vehicle.registration_number %></td>
                <td><%= expense.category.titleize %></td>
                <td class="text-red"><%= number_to_currency(expense.amount) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<script>
  // ── Embedded data from Rails ──────────────────────────────────────────────
  var CHART_DATA = {
    months:         <%= @months.to_json.html_safe %>,
    revenues:       <%= @revenues.to_json.html_safe %>,
    expensesChart:  <%= @expenses_chart.to_json.html_safe %>,
    categoryData:   <%= @expense_category_data.to_json.html_safe %>,
    categoryLabels: <%= @expense_category_labels.to_json.html_safe %>
  };

  // ── Chart initialisation ──────────────────────────────────────────────────
  function initializeCharts() {
    // Revenue vs Expenses
    var revenueCanvas = document.getElementById('revenueExpenseChart');
    if (revenueCanvas) {
      if (revenueCanvas._chart) revenueCanvas._chart.destroy();
      revenueCanvas._chart = new Chart(revenueCanvas.getContext('2d'), {
        type: 'line',
        data: {
          labels: CHART_DATA.months,
          datasets: [
            {
              label: 'Revenue',
              data: CHART_DATA.revenues,
              borderColor: '#1a9e6e',
              backgroundColor: 'rgba(26,158,110,0.08)',
              tension: 0.4,
              fill: true,
              pointRadius: 3,
              pointHoverRadius: 5,
              borderWidth: 2
            },
            {
              label: 'Expenses',
              data: CHART_DATA.expensesChart,
              borderColor: '#d63d2f',
              backgroundColor: 'rgba(214,61,47,0.07)',
              tension: 0.4,
              fill: true,
              pointRadius: 3,
              pointHoverRadius: 5,
              borderWidth: 2
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: {
              position: 'bottom',
              labels: { font: { family: 'Inconsolata', size: 11 }, boxWidth: 10, padding: 12 }
            }
          },
          scales: {
            x: { grid: { color: 'rgba(0,0,0,0.04)' }, ticks: { font: { family: 'Inconsolata', size: 10 } } },
            y: { grid: { color: 'rgba(0,0,0,0.04)' }, ticks: { font: { family: 'Inconsolata', size: 10 } } }
          }
        }
      });
    }

    // Expense Breakdown
    var expenseCanvas = document.getElementById('expenseBreakdownChart');
    if (expenseCanvas) {
      if (expenseCanvas._chart) expenseCanvas._chart.destroy();
      var hasData = CHART_DATA.categoryData.length > 1 || CHART_DATA.categoryLabels[0] !== 'No Data Available';
      if (hasData) {
        expenseCanvas._chart = new Chart(expenseCanvas.getContext('2d'), {
          type: 'pie',
          data: {
            labels: CHART_DATA.categoryLabels,
            datasets: [{
              data: CHART_DATA.categoryData,
              backgroundColor: ['#1a9e6e','#c07b1a','#d63d2f','#7c3aed','#db2777','#0891b2','#4f46e5'],
              borderWidth: 0
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
              legend: {
                position: 'bottom',
                labels: { font: { family: 'Inconsolata', size: 10 }, boxWidth: 10, padding: 8 }
              },
              tooltip: {
                callbacks: {
                  label: function(ctx) {
                    var total = ctx.dataset.data.reduce(function(a, b) { return a + b; }, 0);
                    var pct   = ((ctx.raw / total) * 100).toFixed(1);
                    var amt   = new Intl.NumberFormat('en-MW', { style: 'currency', currency: 'MWK' }).format(ctx.raw);
                    return ctx.label + ': ' + amt + ' (' + pct + '%)';
                  }
                }
              }
            }
          }
        });
      } else {
        var ctx2 = expenseCanvas.getContext('2d');
        ctx2.font = '13px Inconsolata';
        ctx2.fillStyle = '#5c6070';
        ctx2.textAlign = 'center';
        ctx2.fillText('No expense data available', expenseCanvas.width / 2, expenseCanvas.height / 2);
      }
    }
  }

  // ── Safe loader — waits for Chart.js before calling initializeCharts ─────
  function loadChartJs(callback) {
    if (window.Chart) { callback(); return; }
    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js';
    s.onload = callback;
    document.head.appendChild(s);
  }

  document.addEventListener('DOMContentLoaded', function() { loadChartJs(initializeCharts); });
  document.addEventListener('turbo:load',       function() { loadChartJs(initializeCharts); });
</script>
