<%= form_with(model: product, local: true, class: "form") do |f| %>
  <% if product.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h4>
      <ul>
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <div class="grid grid-2">
    <div class="form-group">
      <%= f.label :name, "Product Name *" %>
      <%= f.text_field :name, class: "form-control", placeholder: "e.g., Sand, Gravel, Premium Diesel", required: true %>
    </div>
    
    <div class="form-group">
      <%= f.label :unit, "Unit of Measurement *" %>
      <%= f.text_field :unit, class: "form-control", placeholder: "e.g., tons, liters, cubic meters, pieces", required: true %>
    </div>
    
    <div class="form-group">
      <%= f.label :price, "Price per Unit *" %>
      <%= f.number_field :price, class: "form-control", step: "any", placeholder: "0.00", required: true %>
    </div>
    
    <div class="form-group full-width">
      <%= f.label :description, "Description *" %>
      <%= f.text_area :description, class: "form-control", rows: 4, placeholder: "Enter product description...", required: true %>
    </div>
    
    <div class="form-group">
      <%= f.label :active, "Status" %>
      <%= f.select :active, options_for_select([["Active", true], ["Inactive", false]], product.active), class: "form-control" %>
      <small style="color: #64748b;">Inactive products won't appear in sales forms</small>
    </div>
  </div>
  
  <div style="margin-top: 1.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
    <%= f.submit submit_text, class: "btn btn-primary" %>
    <%= link_to "Cancel", products_path, class: "btn btn-secondary" %>
  </div>
<% end %>
